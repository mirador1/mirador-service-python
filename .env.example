# Template for local environment configuration.
# Copy to .env (gitignored) and fill in your values.
# Never commit secrets — use a secrets manager (Vault, AWS SSM) in production.
#
# .env and .env.example MUST have the same KEYS (values may differ).
# When adding/removing a variable, update both files together.

# ── Server ────────────────────────────────────────────────────────────────────
MIRADOR_SERVER_HOST=0.0.0.0
MIRADOR_SERVER_PORT=8080
MIRADOR_DEV_MODE=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
MIRADOR_DB__HOST=localhost
MIRADOR_DB__PORT=5432
MIRADOR_DB__NAME=mirador
MIRADOR_DB__USER=mirador
MIRADOR_DB__PASSWORD=mirador

# ── Redis ─────────────────────────────────────────────────────────────────────
MIRADOR_REDIS__HOST=localhost
MIRADOR_REDIS__PORT=6379
MIRADOR_REDIS__DB=0

# ── Kafka ─────────────────────────────────────────────────────────────────────
MIRADOR_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
MIRADOR_KAFKA__CUSTOMER_REQUEST_TOPIC=customer.enrich.request
MIRADOR_KAFKA__CUSTOMER_REPLY_TOPIC=customer.enrich.reply
MIRADOR_KAFKA__ENRICH_TIMEOUT_SECONDS=5

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(64))"
MIRADOR_JWT__SECRET=change-me-in-prod-use-token_urlsafe-64
MIRADOR_JWT__ALGORITHM=HS256
MIRADOR_JWT__ACCESS_TOKEN_EXPIRE_MINUTES=15
MIRADOR_JWT__REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenTelemetry ────────────────────────────────────────────────────────────
MIRADOR_OTEL_ENDPOINT=http://localhost:4318
MIRADOR_OTEL_SERVICE_NAME=mirador-service-python

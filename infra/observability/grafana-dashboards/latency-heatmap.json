{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "targetBlank": true,
      "title": "← back to SLO Overview",
      "type": "link",
      "url": "/d/mirador-slo-overview/slo-overview-mirador"
    }
  ],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Latency distribution heatmap : x=time, y=latency bucket, color=request count. Reveals tail-latency patterns invisible in p99 line charts (e.g. bimodal distributions, slow-mode regressions).",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "scaleDistribution": {"type": "linear"}
          }
        }
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Spectral",
          "steps": 64
        },
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "filterValues": {"le": 1e-9},
        "legend": {"show": true},
        "rowsFrame": {"layout": "auto"},
        "showValue": "never",
        "tooltip": {"mode": "single", "showColorScale": false, "yHistogram": false},
        "yAxis": {"axisPlacement": "left", "reverse": false, "unit": "s"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (le) (rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{ le }}",
          "refId": "A"
        }
      ],
      "title": "Latency heatmap — all endpoints (1m bucket)",
      "type": "heatmap"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Same heatmap but filtered to ONE endpoint via the dropdown. Pick the endpoint that's dragging the SLO from the breakdown dashboard.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "scaleDistribution": {"type": "linear"}
          }
        }
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 12},
      "id": 2,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {"exponent": 0.5, "mode": "scheme", "scale": "exponential", "scheme": "Spectral", "steps": 64},
        "yAxis": {"unit": "s"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (le) (rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\",path_template=\"$path_template\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{ le }}",
          "refId": "A"
        }
      ],
      "title": "Latency heatmap — endpoint $uri (1m bucket)",
      "type": "heatmap"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["slo", "mirador", "sre", "latency"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "/customers", "value": "/customers"},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(starlette_requests_total{job=\"mirador-service-python\"}, path_template)",
        "includeAll": false,
        "multi": false,
        "name": "path_template",
        "options": [],
        "query": {"query": "label_values(starlette_requests_total{job=\"mirador-service-python\"}, path_template)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Latency Heatmap — Mirador",
  "uid": "mirador-py-latency-heatmap",
  "version": 1
}

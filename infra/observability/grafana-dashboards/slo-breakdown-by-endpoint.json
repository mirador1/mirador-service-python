{
  "annotations": {
    "list": [
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "enable": true,
        "iconColor": "rgba(255, 96, 0, 0.9)",
        "name": "Chaos — slow-query",
        "expr": "changes(starlette_requests_total{job=\"mirador-service-python\",path_template=\"/customers/diagnostic/slow-query\"}[1m]) > 0",
        "step": "1m",
        "tagKeys": "path_template",
        "titleFormat": "Chaos: slow-query",
        "textFormat": "Synthetic latency injection — see customer/diagnostic_router.py#slow_query. Burns latency budget.",
        "useValueForTime": false
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "enable": true,
        "iconColor": "rgba(220, 53, 69, 0.9)",
        "name": "Chaos — db-failure",
        "expr": "changes(starlette_requests_total{job=\"mirador-service-python\",path_template=\"/customers/diagnostic/db-failure\"}[1m]) > 0",
        "step": "1m",
        "tagKeys": "path_template",
        "titleFormat": "Chaos: db-failure",
        "textFormat": "Deliberate DB failure via customer/diagnostic_router.py#db_failure. Burns availability budget.",
        "useValueForTime": false
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "enable": true,
        "iconColor": "rgba(108, 117, 125, 0.9)",
        "name": "Chaos — kafka-timeout",
        "expr": "changes(starlette_requests_total{job=\"mirador-service-python\",path_template=\"/customers/diagnostic/kafka-timeout\"}[1m]) > 0",
        "step": "1m",
        "tagKeys": "path_template",
        "titleFormat": "Chaos: kafka-timeout",
        "textFormat": "Synthetic Kafka 504 via customer/diagnostic_router.py#kafka_timeout. Distinct from real /customers/{id}/enrich timeouts on the enrichment SLO.",
        "useValueForTime": false
      },
      {
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "enable": true,
        "iconColor": "rgba(255, 193, 7, 0.9)",
        "name": "Real 5xx (catch-all)",
        "expr": "changes(starlette_requests_total{job=\"mirador-service-python\",path_template=~\"/customers.*\",path_template!~\"/customers/diagnostic/(slow-query|db-failure|kafka-timeout)\",status=~\"5..\"}[1m]) > 0",
        "step": "1m",
        "tagKeys": "path_template,status",
        "titleFormat": "Real 5xx",
        "textFormat": "Non-chaos customer endpoint returned 5xx — investigate. Excludes the 3 chaos diagnostic URIs which are handled by dedicated annotations.",
        "useValueForTime": false
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "targetBlank": true,
      "title": "← back to SLO Overview",
      "type": "link",
      "url": "/d/mirador-slo-overview/slo-overview-mirador"
    }
  ],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Top 10 endpoints by 5xx error rate. Identifies which endpoint is dragging the availability SLO.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.001},
              {"color": "red", "value": 0.01}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "topk(10,\n  sum by (path_template) (rate(starlette_requests_total{job=\"mirador-service-python\",status=~\"5..\"}[5m]))\n  /\n  sum by (path_template) (rate(starlette_requests_total{job=\"mirador-service-python\"}[5m]))\n)",
          "legendFormat": "{{ path_template }}",
          "refId": "A"
        }
      ],
      "title": "Top 10 endpoints — 5xx error ratio (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Top 10 endpoints by p99 latency. Identifies which endpoint is dragging the latency SLO.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1.0}
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "topk(10,\n  histogram_quantile(0.99,\n    sum by (path_template, le) (rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\"}[5m]))\n  )\n)",
          "legendFormat": "{{ path_template }}",
          "refId": "A"
        }
      ],
      "title": "Top 10 endpoints — p99 latency (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Request rate by endpoint — context for the error/latency panels above. High-traffic endpoints contribute proportionally more to SLO budget burn.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 3,
      "options": {
        "legend": {"calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "topk(10, sum by (path_template) (rate(starlette_requests_total{job=\"mirador-service-python\"}[5m])))",
          "legendFormat": "{{ path_template }}",
          "refId": "A"
        }
      ],
      "title": "Request rate by endpoint (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Budget burn contribution per endpoint = (endpoint_error_rate × endpoint_request_share). The endpoint with the highest score is what to fix first.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.0001},
              {"color": "red", "value": 0.001}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "id": 4,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "topk(10,\n  sum by (path_template) (rate(starlette_requests_total{job=\"mirador-service-python\",status=~\"5..\"}[5m]))\n  /\n  ignoring (path_template) group_left sum(rate(starlette_requests_total{job=\"mirador-service-python\"}[5m]))\n)",
          "legendFormat": "{{ path_template }}",
          "refId": "A"
        }
      ],
      "title": "Budget burn contribution by endpoint (5m)",
      "type": "timeseries"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["slo", "mirador", "sre", "breakdown"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SLO Breakdown by Endpoint — Mirador",
  "uid": "mirador-py-slo-breakdown-by-endpoint",
  "version": 1
}

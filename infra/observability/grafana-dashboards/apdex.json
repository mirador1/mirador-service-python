  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Apdex (Application Performance Index) = (Satisfied + Tolerating/2) / Total. Single 0-1 score capturing user-perceived performance. Targets : T (satisfied) = 500ms ; F (frustrating) = 2000ms.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.7},
              {"color": "yellow", "value": 0.85},
              {"color": "green", "value": 0.94}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(\n  sum(rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\",le=\"0.5\"}[5m]))\n  +\n  sum(rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\",le=\"2\"}[5m]))\n) / 2 /\n  sum(rate(starlette_requests_total{job=\"mirador-service-python\"}[5m]))",
          "legendFormat": "Apdex 5m",
          "refId": "A"
        }
      ],
      "title": "Apdex — service-wide (T=500ms, F=2000ms)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Apdex categories breakdown : satisfied (< T = 500ms) + tolerating (T..F = 500ms..2s) + frustrated (> F = 2s).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 25, "lineWidth": 2, "stacking": {"group": "A", "mode": "percent"}},
          "unit": "percentunit"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "satisfied"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "tolerating"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "frustrated"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\",le=\"0.5\"}[5m])) /\nsum(rate(starlette_requests_total{job=\"mirador-service-python\"}[5m]))",
          "legendFormat": "satisfied",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(\n  sum(rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\",le=\"2\"}[5m]))\n  -\n  sum(rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\",le=\"0.5\"}[5m]))\n) /\n  sum(rate(starlette_requests_total{job=\"mirador-service-python\"}[5m]))",
          "legendFormat": "tolerating",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(\n  sum(rate(starlette_requests_total{job=\"mirador-service-python\"}[5m]))\n  -\n  sum(rate(starlette_request_duration_seconds_bucket{job=\"mirador-service-python\",le=\"2\"}[5m]))\n) /\n  sum(rate(starlette_requests_total{job=\"mirador-service-python\"}[5m]))",
          "legendFormat": "frustrated",
          "refId": "C"
        }
      ],
      "title": "Apdex breakdown (satisfied / tolerating / frustrated)",
      "type": "timeseries"
    },

# uv
.uv-cache/

# mutmut scratch directory — generated when running `uv run mutmut run`.
# Contains mutated copies of source files ; not source-of-truth.
mutants/
.mutmut-cache
# uv.lock is COMMITTED for reproducible CI builds (`uv sync --frozen` in
# .gitlab-ci/test.yml requires it). Per ~/.claude/CLAUDE.md "Pin every
# upstream reference. No floating tags." — same rule that pins exact
# versions in pyproject.toml extends to the lockfile.


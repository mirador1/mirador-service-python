# Mirrors .gitignore minus what Docker needs (= src + pyproject + uv.lock).
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.git/
.gitignore
.gitlab-ci/
.gitlab-ci.yml
.github/
.idea/
.vscode/
.DS_Store
docs/
tests/
alembic/
infra/
bin/
# Exclude doc Markdown but KEEP README.md — it's referenced by pyproject.toml
# (`readme = "README.md"`) and uv build needs it present.
*.md
!README.md
*.log
.env
.env.example
docker-compose*.yml
